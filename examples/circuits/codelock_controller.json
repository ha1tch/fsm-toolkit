{
  "name": "controller",
  "type": "mealy",
  "states": [
    "LOCKED",
    "UNLOCKING",
    "UNLOCKED",
    "RELOCKING",
    "ALARM",
    "LOCKOUT"
  ],
  "alphabet": [
    "unlock_cmd",
    "alarm_cmd",
    "timeout",
    "clear"
  ],
  "output_alphabet": [
    "lock_open",
    "siren",
    "led_green",
    "led_red"
  ],
  "initial": "LOCKED",
  "transitions": [
    {
      "from": "LOCKED",
      "input": "unlock_cmd",
      "to": "UNLOCKING",
      "output": "led_green"
    },
    {
      "from": "LOCKED",
      "input": "alarm_cmd",
      "to": "ALARM",
      "output": "led_red, siren"
    },
    {
      "from": "UNLOCKING",
      "input": "timeout",
      "to": "UNLOCKED",
      "output": "lock_open, led_green"
    },
    {
      "from": "UNLOCKED",
      "input": "timeout",
      "to": "RELOCKING"
    },
    {
      "from": "RELOCKING",
      "input": "timeout",
      "to": "LOCKED"
    },
    {
      "from": "ALARM",
      "input": "timeout",
      "to": "LOCKOUT",
      "output": "led_red"
    },
    {
      "from": "LOCKOUT",
      "input": "timeout",
      "to": "LOCKED"
    },
    {
      "from": "LOCKOUT",
      "input": "clear",
      "to": "LOCKED"
    }
  ],
